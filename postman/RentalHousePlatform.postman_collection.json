    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register (Tenant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data?.token?.access_token) pm.environment.set('access_token', data.token.access_token);",
                  "  if (data?.token?.refresh_token) pm.environment.set('refresh_token', data.token.refresh_token);",
                  "  if (data?.user?.id) pm.environment.set('user_id', data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{tenant_email}}\",\n  \"password\": \"{{tenant_password}}\",\n  \"role\": \"TENANT\",\n  \"full_name\": \"Tenant User\",\n  \"phone\": \"0123456789\"\n}\n"
